# OS
.DS_Store
Thumbs.db

# Editors / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs / temp
*.log
tmp/
.tmp/
*.local

# Secrets / env
.env
.env.*
!.env.example
*.key

# Personal archive data — NEVER commit a user's actual cognitive archive.
# The repo ships the framework/schema, not anyone's private growth data.
*.archive.md
archive-data/
my-archive/

# Internal working notes — design docs and any superpowers scaffolding.
# These are our process artifacts, irrelevant to people installing the plugin.
docs/design/
docs/superpowers/

# Embedding model assets — fetched via scripts/fetch-model.sh, never committed
# (the .onnx is ~470MB). The repo ships code; users fetch the model once.
assets/e5-small/*.onnx
assets/e5-small/*.json
assets/e5-small/*.onnx_data

# Compiled binaries (anchor to root so cmd/witness/ source is NOT ignored)
/bin/
/witness
/witness-*
/witness.exe
*.test
*.exe
*.out
*.prof
# Release archives (produced by `make package-windows`, attached to releases)
*.zip
# Release staging dir (raw cross-compiled binaries + SHA256SUMS produced by the
# release build, attached to the GitHub Release — never committed). Anchored to
# root; the *.zip rule above already covers the Windows zips here, but the raw
# ELF/Mach-O binaries + SHA256SUMS.txt are otherwise stageable (issue #49 I6).
/dist/

# Generated npm publish payload. Produced by `make npm-opencode-package`.
/npm/opencode/dist/
/npm/opencode/prompts/
/npm/opencode/assets/
/npm/opencode/node_modules/
/npm/opencode/*.tgz
/npm/platform/*/bin/
